# Lokale PostgreSQL via docker-compose (zie docker-compose.yml: `docker compose up -d db`)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uren_dashboard"

# Gemini API (gebruikt voor de AI-verdeelsleutel en de AI-PV-tekst)
# Maak een sleutel via https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
