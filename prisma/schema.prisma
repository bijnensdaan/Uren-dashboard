generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id                 String          @id @default(cuid())
  name               String
  profileCategoryId  String
  active             Boolean         @default(true)
  weeklyCapacityHours Float          @default(40)
  profileCategory    ProfileCategory @relation(fields: [profileCategoryId], references: [id])
  timeEntries        TimeEntry[]

  @@index([profileCategoryId])
}

model ProfileCategory {
  id                          String                       @id @default(cuid())
  name                        String                       @unique
  defaultAllocationPercentage Float
  active                      Boolean                      @default(true)
  employees                   Employee[]
  timeEntries                 TimeEntry[]
  contractAllocationTemplates ContractAllocationTemplate[]
  simulationLines             SimulationLine[]
  profileRates                ProfileRate[]
}

model ProfileRate {
  id                String          @id @default(cuid())
  contractId        String
  profileCategoryId String
  unitPrice         Float
  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  profileCategory   ProfileCategory @relation(fields: [profileCategoryId], references: [id])

  @@unique([contractId, profileCategoryId])
  @@index([profileCategoryId])
}

model Contract {
  id                          String                       @id @default(cuid())
  code                        String                       @unique
  name                        String
  totalBudgetHours            Float
  startDate                   DateTime
  endDate                     DateTime
  warningThreshold            Float                        @default(85)
  criticalThreshold           Float                        @default(95)
  active                      Boolean                      @default(true)
  vatPercentage               Float                        @default(21)
  totalBudgetAmount           Float?
  specificationCode           String?
  orderLetterTitle            String?
  orderLetterReference        String?
  domainManagerName           String?
  domainManagerRole           String?
  domainManagerOrg            String?
  projectLeadNames            String?
  projectLeadOrg              String?
  aiInsightsJson              String?
  aiInsightsStatus            String                       @default("none")
  aiInsightsModel             String?
  aiInsightsAt                DateTime?
  tasks                       Task[]
  timeEntries                 TimeEntry[]
  allocationTemplates         ContractAllocationTemplate[]
  profileRates                ProfileRate[]
  simulations                 Simulation[]
  deliveryReports             DeliveryReport[]
  allocationSuggestions       AllocationSuggestion[]
  invoices                    Invoice[]
  projectPlans                ProjectPlan[]
  documents                   Document[]

  @@index([active])
}

model Task {
  id          String      @id @default(cuid())
  name        String
  contractId  String
  active      Boolean     @default(true)
  contract    Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@unique([contractId, name])
  @@index([contractId])
}

model TimeEntry {
  id                String          @id @default(cuid())
  employeeId        String
  date              DateTime
  hours             Float
  taskId            String
  contractId        String
  profileCategoryId String
  notes             String?
  clockIn           String?         // HH:MM, bv "09:00" (alleen voor tracker-sessies)
  clockOut          String?         // HH:MM, bv "17:30"
  pauseMinutes      Int?            @default(0)  // pauze in minuten
  createdAt         DateTime        @default(now())
  employee          Employee        @relation(fields: [employeeId], references: [id])
  task              Task            @relation(fields: [taskId], references: [id])
  contract          Contract        @relation(fields: [contractId], references: [id])
  profileCategory   ProfileCategory @relation(fields: [profileCategoryId], references: [id])

  @@index([contractId, date])
  @@index([taskId])
  @@index([employeeId])
  @@index([profileCategoryId])
}

model ContractAllocationTemplate {
  id                String          @id @default(cuid())
  contractId        String
  profileCategoryId String
  targetPercentage  Float
  contract          Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  profileCategory   ProfileCategory @relation(fields: [profileCategoryId], references: [id])

  @@unique([contractId, profileCategoryId])
  @@index([profileCategoryId])
}

model Simulation {
  id              String           @id @default(cuid())
  contractId      String
  inputTotalHours Float
  sourceType      String
  status          String           @default("draft")
  createdAt       DateTime         @default(now())
  contract        Contract         @relation(fields: [contractId], references: [id])
  lines           SimulationLine[]
  deliveryReport  DeliveryReport?

  @@index([contractId])
}

model SimulationLine {
  id                String          @id @default(cuid())
  simulationId      String
  profileCategoryId String
  proposedHours     Float
  adjustedHours     Float?
  finalHours        Float
  targetPercentage  Float
  simulation        Simulation      @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  profileCategory   ProfileCategory @relation(fields: [profileCategoryId], references: [id])

  @@unique([simulationId, profileCategoryId])
  @@index([profileCategoryId])
}

model AllocationSuggestion {
  id            String    @id @default(cuid())
  contractId    String
  sourceText    String
  suggestedJson String
  model         String
  createdAt     DateTime  @default(now())
  acceptedAt    DateTime?
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model DeliveryReport {
  id               String     @id @default(cuid())
  simulationId     String     @unique
  contractId       String
  generatedAt      DateTime   @default(now())
  htmlContent      String
  aiDraftStatus    String     @default("not_requested")
  aiDraftText      String?
  aiModel          String?
  aiGeneratedAt    DateTime?
  aiSourceSnapshot String?
  pvNarrativeJson  String?
  pvDataJson       String?
  simulation       Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  contract         Contract   @relation(fields: [contractId], references: [id])
  invoice          Invoice?

  @@index([contractId])
}

model ProjectPlan {
  id              String    @id @default(cuid())
  contractId      String
  status          String    @default("concept")
  model           String?
  totalHours      Float
  phasesJson      String
  assignmentsJson String?
  createdAt       DateTime  @default(now())
  approvedAt      DateTime?
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model Invoice {
  id               String         @id @default(cuid())
  contractId       String
  deliveryReportId String         @unique
  periodStart      DateTime?
  periodEnd        DateTime?
  amountExclVat    Float
  vatAmount        Float
  amountInclVat    Float
  createdAt        DateTime       @default(now())
  contract         Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  deliveryReport   DeliveryReport @relation(fields: [deliveryReportId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model Document {
  id           String   @id @default(cuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fileName     String   // originele bestandsnaam, bv "Opdrachtbrief AVSA24.docx"
  storedPath   String   // pad RELATIEF t.o.v. de uploads-root, bv "<cuid>.docx"
  mimeType     String   // application/pdf | ...wordprocessingml.document | text/plain
  fileSize     Int
  kind         String   @default("opdrachtbrief")
  uploadedAt   DateTime @default(now())

  @@index([contractId])
}
